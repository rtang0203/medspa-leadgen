# Google Places API key (required for real discovery, not needed in MOCK_MODE)
GOOGLE_PLACES_API_KEY=

# Anthropic API key (required for LLM hook generation, not needed in MOCK_MODE)
ANTHROPIC_API_KEY=

# Email finder API key (optional, for future email provider integration)
EMAIL_API_KEY=

# Database path (default: leads.db)
DB_PATH=leads.db

# Mock mode: set to false when API keys are configured
# Auto-detected if API keys are missing
MOCK_MODE=true
